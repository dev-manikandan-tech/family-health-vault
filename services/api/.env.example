NODE_ENV=development
PORT=3000

# Supabase Auth (required in production; JWT_SECRET fallback is never used in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override Supabase JWT issuer/audience validation.
# Defaults to ${SUPABASE_URL}/auth/v1 and "authenticated".
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=

# Fallback shared secret for local development and tests using the fake Supabase client.
# Do NOT set this in production; HS256 tokens are rejected when NODE_ENV=production.
JWT_SECRET=change-me-in-development

DB_TYPE=postgres
DATABASE_URL=postgresql://fhv:fhv@localhost:5432/fhv
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fhv
DB_PASSWORD=fhv
DB_NAME=fhv

REDIS_URL=redis://localhost:6379

# Document processing queue: 'bullmq' for production, 'fake' for sync test/CI.
DOCUMENT_QUEUE_PROVIDER=fake

# S3-compatible object storage (MinIO, AWS S3, GCS via S3 interop)
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=family-health-vault
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_SSE_ALGORITHM=aws:kms
STORAGE_SSE_KMS_KEY_ID=
STORAGE_PRESIGNED_URL_TTL=300

RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60
